            "url": {
              "raw": "{{baseUrl}}/api/files",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "files"
              ]
            },
            "description": "multipart/form-data. Size limit — env UPLOAD_MAX_FILESIZE. root -> public; a file in a section inherits its visibility. Response contains id, isPublic, privateUrl, publicUrl. Saves {{fileId}}."
